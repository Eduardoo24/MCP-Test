# Copy to `.env` and adjust if needed. The server reads these on startup.

# Network binding. Default 127.0.0.1 — only your machine can reach the server.
# Set MCP_HOST=0.0.0.0 only if you understand the security implications:
# without authentication, *anyone* on your LAN can call every tool.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Single Streamable HTTP endpoint (no separate /sse + /messages routes).
MCP_PATH=/mcp

# Comma-separated list of Origin header values accepted by the server.
# Used for DNS-rebinding protection.
MCP_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# DEBUG | INFO | WARNING | ERROR | CRITICAL
MCP_LOG_LEVEL=INFO

# Override only when running the client against a non-default server.
# MCP_SERVER_URL=http://127.0.0.1:8000/mcp
